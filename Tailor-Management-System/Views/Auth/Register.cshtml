@{
    Layout = null;
    ViewData["Title"] = "Register";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Tailor Management System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', system-ui, sans-serif;
            background-color: #F4F4F5;
            min-height: 100vh;
        }
        .auth-wrapper {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }
        .auth-left {
            flex: 1;
            background: linear-gradient(135deg, #4F46E5 0%, #818CF8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px;
        }
        .auth-left h2 {
            color: white;
            font-size: 48px;
            font-weight: 800;
            text-align: center;
            line-height: 1.2;
        }
        .auth-right {
            width: 480px;
            background: #1B2236;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px 40px;
            overflow-y: auto;
        }
        .auth-form { width: 100%; }
        .auth-form h3 { color: white; font-size: 28px; font-weight: 800; margin-bottom: 8px; }
        .auth-form p { color: #9CA3AF; font-size: 15px; margin-bottom: 32px; }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; color: #D1D5DB; font-size: 14px; font-weight: 600; margin-bottom: 8px; }
        .form-group input {
            width: 100%; padding: 14px 16px; background: #2A3347;
            border: 1px solid #374151; border-radius: 8px; color: white;
            font-size: 15px; outline: none; transition: border-color 0.2s;
        }
        .form-group input:focus { border-color: #6366F1; }
        .auth-btn {
            width: 100%; padding: 16px; background: #4F46E5; color: white;
            border: none; border-radius: 8px; font-size: 16px; font-weight: 700;
            cursor: pointer; margin-top: 8px; transition: background 0.2s;
        }
        .auth-btn:hover { background: #4338CA; }
        .auth-link { text-align: center; margin-top: 24px; color: #9CA3AF; font-size: 14px; }
        .auth-link a { color: #818CF8; text-decoration: none; font-weight: 600; }
        .error-alert {
            background: #FEE2E2; border: 1px solid #FECACA; color: #991B1B;
            padding: 12px 16px; border-radius: 8px; font-size: 14px;
            margin-bottom: 20px; font-weight: 500;
        }
        @@media (max-width: 768px) {
            .auth-left { display: none; }
            .auth-right { width: 100%; }
        }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-left">
            <h2>Tailor Management System</h2>
        </div>
        <div class="auth-right">
            <div class="auth-form">
                <h3>Create an Account</h3>
                <p>Register your Tailor Shop</p>

                @if (ViewBag.Error != null)
                {
                    <div class="error-alert">@ViewBag.Error</div>
                }

                <form method="post" action="/Auth/Register">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label>Full Name *</label>
                        <input type="text" name="fullName" placeholder="Your full name" required />
                    </div>
                    <div class="form-group">
                        <label>Shop Name *</label>
                        <input type="text" name="shopName" placeholder="Your shop name" required />
                    </div>
                    <div class="form-group">
                        <label>Email *</label>
                        <input type="email" name="email" placeholder="your@email.com" required />
                    </div>
                    <div class="form-group">
                        <label>Password *</label>
                        <input type="password" name="password" placeholder="••••••••" minlength="6" required />
                    </div>
                    <button type="submit" class="auth-btn">Register</button>
                </form>

                <div style="display: flex; align-items: center; margin: 24px 0;">
                    <div style="flex: 1; height: 1px; background: #374151;"></div>
                    <span style="margin: 0 10px; color: #9CA3AF; font-size: 14px; font-weight: 500;">OR</span>
                    <div style="flex: 1; height: 1px; background: #374151;"></div>
                </div>

                <div style="display: flex; justify-content: center; margin-bottom: 24px;">
                    <div id="g_id_onload"
                         data-client_id="232033818874-qp3n4be18p3oba9ogbv98n265omn649b.apps.googleusercontent.com"
                         data-context="use"
                         data-ux_mode="popup"
                         data-callback="handleGoogleLogin"
                         data-auto_prompt="false">
                    </div>
                    <div class="g_id_signin"
                         data-type="standard"
                         data-shape="rectangular"
                         data-theme="outline"
                         data-text="signup_with"
                         data-size="large"
                         data-logo_alignment="left">
                    </div>
                </div>

                <div class="auth-link">
                    Already have an account? <a href="/Auth/Login">Sign in here</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        async function handleGoogleLogin(response) {
            try {
                const res = await fetch('/Auth/GoogleLogin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: response.credential })
                });
                const data = await res.json();
                if (data.success) {
                    window.location.href = '/Home/Index';
                } else {
                    alert('Google Authentication failed: ' + (data.message || 'Unknown error'));
                }
            } catch (err) {
                console.error(err);
                alert('Failed to connect to server.');
            }
        }
    </script>
</body>
</html>
