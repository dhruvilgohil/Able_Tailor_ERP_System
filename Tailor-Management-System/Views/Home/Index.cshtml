@{
    ViewData["Title"] = "Dashboard";
}

<div style="display:flex;flex-direction:column;gap:var(--spacing-2xl);">

    <!-- STAT CARDS (Premium Glassmorphism Style) -->
    <div class="stats-grid">
        <div class="stat-card premium card-blue">
            <div class="stat-content">
                <p class="stat-label">Total Customer</p>
                <h3 class="stat-value" id="stat-customers">—</h3>
            </div>
            <div class="stat-icon">
                <i data-lucide="users" style="width:32px;height:32px;"></i>
            </div>
        </div>
        <div class="stat-card premium card-emerald">
            <div class="stat-content">
                <p class="stat-label">Total Orders</p>
                <h3 class="stat-value" id="stat-orders">—</h3>
            </div>
            <div class="stat-icon">
                <i data-lucide="receipt" style="width:32px;height:32px;"></i>
            </div>
        </div>
        <div class="stat-card premium card-amber">
            <div class="stat-content">
                <p class="stat-label">Pending Orders</p>
                <h3 class="stat-value" id="stat-pending">—</h3>
            </div>
            <div class="stat-icon">
                <i data-lucide="clock" style="width:32px;height:32px;"></i>
            </div>
        </div>
        <div class="stat-card premium card-rose">
            <div class="stat-content">
                <p class="stat-label">Total Income</p>
                <h3 class="stat-value" id="stat-income">—</h3>
            </div>
            <div class="stat-icon">
                <i data-lucide="wallet" style="width:32px;height:32px;"></i>
            </div>
        </div>
    </div>

    <!-- RECENT ORDERS TABLE -->
    <div class="table-wrapper">
        <div id="dash-loading" style="padding:32px;text-align:center;color:#9CA3AF;">Loading orders...</div>
        <table class="data-table" id="dash-table" style="display:none;">
            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Services</th>
                    <th style="text-align:center;">Status</th>
                    <th>Tailor</th>
                    <th>Date</th>
                    <th style="text-align:center;">Action</th>
                </tr>
            </thead>
            <tbody id="dash-tbody"></tbody>
        </table>
    </div>
</div>

<!-- View Order Modal -->
<div class="modal-overlay" id="view-order-modal">
    <div class="modal-box">
        <div class="modal-header-title">
            <h2>Order Details</h2>
        </div>
        <div class="modal-divider"></div>
        <div id="view-order-content"></div>
        <button class="btn-primary-full" onclick="closeModal('view-order-modal')">Close</button>
    </div>
</div>

@section Scripts {
<script>
async function loadDashboard() {
    try {
        const [customers, orders, income] = await Promise.all([
            apiFetch('/api/customers'),
            apiFetch('/api/orders'),
            apiFetch('/api/income')
        ]);

        document.getElementById('stat-customers').textContent = customers.length;
        document.getElementById('stat-orders').textContent = orders.length;
        document.getElementById('stat-pending').textContent = orders.filter(o => o.status === 'Pending').length;
        const totalIncome = income.reduce((s, i) => s + Number(i.amount || 0), 0);
        document.getElementById('stat-income').textContent = '₹ ' + totalIncome.toLocaleString();

        const recent = (orders || []).slice(0, 5);
        const tbody = document.getElementById('dash-tbody');
        tbody.innerHTML = recent.map(o => {
            const dateStr = new Date(o.createdAt).toLocaleDateString('en-GB').replace(/\//g, '-');
            return `<tr>
                <td style="font-weight:600;">${o.customerId?.customerName || o.customerId?.name || 'Unknown'}</td>
                <td style="font-size:14px;">${Array.isArray(o.services) ? o.services.join(', ') : (o.services || '')}</td>
                <td style="text-align:center;">${renderReactStatusBadge(o.status)}</td>
                <td>${o.assignedTailor?.name || '—'}</td>
                <td style="font-size:13px;color:var(--text-secondary);">${dateStr}</td>
                <td style="text-align:center;">
                    <button class="btn-view" onclick='viewOrder(${JSON.stringify(o)})'><i data-lucide="eye" style="width:16px;height:16px;margin-right:4px;"></i> View</button>
                </td>
            </tr>`;
        }).join('');

        document.getElementById('dash-loading').style.display = 'none';
        document.getElementById('dash-table').style.display = 'table';
        lucide.createIcons();
    } catch(e) {
        document.getElementById('dash-loading').textContent = 'Error loading Dashboard.';
    }
}

function renderReactStatusBadge(status) {
    if (!status) return `<span class="status-badge status-Pending">—</span>`;
    const s = status.toLowerCase().replace(/\s+/g, '');
    let cssClass = 'Pending';
    if (s === 'completed') cssClass = 'Completed';
    else if (s === 'inprogress') cssClass = 'InProgress';
    return `<span class="status-badge status-${cssClass}">${status}</span>`;
}

function viewOrder(o) {
    document.getElementById('view-order-content').innerHTML = `
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;margin-bottom:4px;">Customer</p><p style="font-weight:700;">${o.customerId?.customerName||'—'}</p></div>
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;margin-bottom:4px;">Status</p>${renderReactStatusBadge(o.status)}</div>
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;margin-bottom:4px;">Services</p><p>${(o.services||[]).join(', ')||'—'}</p></div>
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;margin-bottom:4px;">Delivery</p><p>${formatDate(o.targetDeliveryDate)}</p></div>
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;margin-bottom:4px;">Tailor</p><p>${o.assignedTailor?.name||'—'}</p></div>
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;margin-bottom:4px;">Payment</p><p>${o.paymentMethod||'—'}</p></div>
            <div style="grid-column:span 2;"><p style="font-size:12px;font-weight:600;color:#6B7280;margin-bottom:4px;">Total</p><p style="font-weight:800;font-size:24px;color:#4F46E5;">₹ ${o.userDefinedTotal||o.calculatedTotal||0}</p></div>
        </div>`;
    openModal('view-order-modal');
}

function openModal(id) { document.getElementById(id).classList.add('show'); }
function closeModal(id) { document.getElementById(id).classList.remove('show'); }

loadDashboard();
</script>
}
