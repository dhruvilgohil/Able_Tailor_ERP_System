@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard">

    <!-- ===== TOP CARDS ===== -->

    <div class="card-grid">

        <div class="dash-card">
            <div class="card-top">
                <div class="card-title">Total Customer</div>
                <div class="card-icon">👤</div>
            </div>
            <div class="card-value">1,240</div>
            <div class="card-growth green">↗ 12%</div>
        </div>

        <div class="dash-card">
            <div class="card-top">
                <div class="card-title">Total Orders</div>
                <div class="card-icon">📋</div>
            </div>
            <div class="card-value">850</div>
            <div class="card-growth green">↗ 5%</div>
        </div>

        <div class="dash-card">
            <div class="card-top">
                <div class="card-title">Pending Orders</div>
                <div class="card-icon">📦</div>
            </div>
            <div class="card-value">42</div>
            <div class="card-growth orange">Working</div>
        </div>

        <div class="dash-card">
            <div class="card-top">
                <div class="card-title">Total Income</div>
                <div class="card-icon">💰</div>
            </div>
            <div class="card-value">₹ 1,24,500</div>
            <div class="card-growth green">↗ 8%</div>
        </div>

    </div>

        
        <div class="table-header-card">
            <div>Customer Name</div>
            <div>Services</div>
            <div>Status</div>
            <div>Assigned Tailor</div>
            <div>Date</div>
            <div></div>
        </div>

        <div class="table-body-card">

            <div class="table-row">
                <div>Jonathan Sterling</div>
                <div>1 Pair</div>
                <div><span class="status working">On Working</span></div>
                <div>Jonathan Sterling</div>
                <div>12-02-2026</div>
                <div><button class="btn-view">View</button></div>
            </div>

            <div class="table-row">
                <div>Jonathan Sterling</div>
                <div>2 Pair</div>
                <div><span class="status start">Start</span></div>
                <div>Jonathan Sterling</div>
                <div>12-02-2026</div>
                <div><button class="btn-view">View</button></div>
            </div>

            <div class="table-row">
                <div>Jonathan Sterling</div>
                <div>5 Pair</div>
                <div><span class="status complete">Complete</span></div>
                <div>Jonathan Sterling</div>
                <div>12-02-2026</div>
                <div><button class="btn-view">View</button></div>
            </div>

            <div class="table-row">
                <div>Jonathan Sterling</div>
                <div>5 Pair</div>
                <div><span class="status complete">Complete</span></div>
                <div>Jonathan Sterling</div>
                <div>12-02-2026</div>
                <div><button class="btn-view">View</button></div>
            </div>

            <div class="table-row">
                <div>Jonathan Sterling</div>
                <div>2 Pair</div>
                <div><span class="status start">Start</span></div>
                <div>Jonathan Sterling</div>
                <div>12-02-2026</div>
                <div><button class="btn-view">View</button></div>
            </div>

        </div>

</div>
