@{
    ViewData["Title"] = "Orders";
}

<div style="display:flex;flex-direction:column;gap:24px;">

    <!-- Top Bar -->
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
        <div class="tabs-bar" style="margin-bottom:0;">
            <button class="tab-btn active" onclick="setTab('all',this)">All Orders</button>
            <button class="tab-btn" onclick="setTab('pending',this)">Pending</button>
            <button class="tab-btn" onclick="setTab('inprogress',this)">In Progress</button>
            <button class="tab-btn" onclick="setTab('completed',this)">Completed</button>
        </div>
        <button class="add-btn" onclick="openAdd()" style="display:flex;align-items:center;gap:8px;">
            <i data-lucide="plus" style="width:18px;height:18px;"></i> Add Order
        </button>
    </div>

    <!-- Status Message -->
    <div id="ord-status" style="padding:32px;text-align:center;color:#94A3B8;font-size:15px;font-weight:600;background:#fff;border-radius:16px;border:1px solid #eef2f7;">
        Loading orders...
    </div>

    <!-- Table -->
    <div class="table-wrapper" id="ord-table-wrap" style="display:none;">
        <table class="data-table" id="ord-table">
            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Services</th>
                    <th style="text-align:center;">Status</th>
                    <th>Delivery Date</th>
                    <th>Payment</th>
                    <th>Total (₹)</th>
                    <th style="text-align:center;">View</th>
                    <th style="text-align:center;">Edit</th>
                    <th style="text-align:center;">Delete</th>
                </tr>
            </thead>
            <tbody id="ord-tbody"></tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div id="ord-pager" style="display:none;justify-content:space-between;align-items:center;padding:16px;background:#fff;border:1px solid #e2e8f0;border-radius:12px;">
        <span id="ord-pager-info" style="color:#64748b;font-size:14px;font-weight:500;"></span>
        <div style="display:flex;gap:8px;align-items:center;">
            <button onclick="prevPage()" class="btn-cancel" style="width:auto;padding:8px 16px;">← Prev</button>
            <span id="ord-pager-pages" style="font-weight:700;padding:0 12px;color:#1e293b;"></span>
            <button onclick="nextPage()" class="btn-cancel" style="width:auto;padding:8px 16px;">Next →</button>
        </div>
    </div>
</div>

<!-- ── Add / Edit Modal ────────────────────────────── -->
<div class="modal-overlay" id="order-modal">
    <div class="modal-box">
        <div class="modal-header-title">
            <h2 id="order-modal-title">Add Order</h2>
            <p id="order-modal-sub">Fill in the details below</p>
        </div>
        <div class="modal-divider"></div>
        <form onsubmit="event.preventDefault(); saveOrder();">
            <input type="hidden" id="order-edit-id" />
            <div class="form-row">
                <div class="form-field"><label>Customer *</label><select id="o-customer" required></select></div>
                <div class="form-field"><label>Tailor</label><select id="o-tailor"><option value="">— None —</option></select></div>
            </div>
            <div class="form-field"><label>Measurement</label><select id="o-measurement"><option value="">— None —</option></select></div>
            <div class="form-field"><label>Services (comma separated)</label><input type="text" id="o-services" placeholder="e.g. Shirt, Pant" /></div>
            <div class="form-row">
                <div class="form-field"><label>Delivery Date</label><input type="date" id="o-date" /></div>
                <div class="form-field"><label>Status</label>
                    <select id="o-status">
                        <option value="Pending">Pending</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Completed">Completed</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-field"><label>Payment</label>
                    <select id="o-payment">
                        <option value="Pending">Pending</option>
                        <option value="Cash">Cash</option>
                        <option value="Online">Online</option>
                    </select>
                </div>
                <div class="form-field"><label>Total (₹)</label><input type="number" id="o-total" value="0" min="0" /></div>
            </div>
            <button type="submit" class="btn-primary-full">Save Order</button>
            <button type="button" class="btn-cancel" onclick="closeModal('order-modal')">Cancel</button>
        </form>
    </div>
</div>

<!-- ── View Modal ──────────────────────────────────── -->
<div class="modal-overlay" id="view-order-modal">
    <div class="modal-box" style="max-width:560px;padding:0;overflow:hidden;">
        <div style="background:linear-gradient(135deg,#4F46E5,#6366f1);padding:24px 28px;position:relative;">
            <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:42px;height:42px;background:rgba(255,255,255,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                    <i data-lucide="package" style="width:20px;height:20px;color:#fff;"></i>
                </div>
                <div>
                    <h2 style="color:#fff;font-size:18px;font-weight:800;margin:0;">Order Details</h2>
                    <p id="view-ord-sub" style="color:rgba(255,255,255,0.75);font-size:13px;margin:2px 0 0;"></p>
                </div>
            </div>
            <button onclick="closeModal('view-order-modal')" style="position:absolute;top:18px;right:18px;background:rgba(255,255,255,0.15);border:none;width:30px;height:30px;border-radius:8px;cursor:pointer;color:#fff;display:flex;align-items:center;justify-content:center;">
                <i data-lucide="x" style="width:16px;height:16px;"></i>
            </button>
        </div>
        <div id="view-order-content" style="padding:24px 28px;display:grid;grid-template-columns:1fr 1fr;gap:12px;"></div>
        <div style="padding:0 28px 24px;"><button class="btn-primary-full" onclick="closeModal('view-order-modal')">Close</button></div>
    </div>
</div>

@section Scripts {
<script>
// ─── Global State ────────────────────────────────────
let ALL   = [];        // raw API data
let VIEW  = [];        // after tab + search filter
let TAB   = 'all';     // 'all' | 'pending' | 'inprogress' | 'completed'
let PAGE  = 1;
let SEARCH = '';
const PER = 8;

window.onGlobalSearch = q => { SEARCH = (q||'').toLowerCase().trim(); PAGE = 1; render(); };

// ─── Helpers ─────────────────────────────────────────
// Parse services - API returns raw JSON array or null
function parseServices(raw) {
    if (!raw) return [];
    if (Array.isArray(raw)) return raw;
    try { return JSON.parse(raw); } catch { return [raw]; }
}

// Safe status token (removes whitespace/punctuation)
function tok(s) { return (s || '').toLowerCase().replace(/[^a-z]/g, ''); }

function badge(status) {
    const t = tok(status);
    let cls = 'Pending', lbl = status || 'Pending';
    if (t === 'inprogress' || t.includes('progress'))  { cls = 'InProgress'; lbl = 'In Progress'; }
    else if (t === 'completed' || t.includes('complet')){ cls = 'Completed';  lbl = 'Completed'; }
    else { lbl = 'Pending'; }
    return `<span class="status-badge status-${cls}">${lbl}</span>`;
}

function field(label, val) {
    return `<div style="background:#f8fafc;border-radius:10px;padding:12px 14px;border:1px solid #eef2f7;">
        <p style="font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;margin:0 0 4px;">${label}</p>
        <p style="font-weight:700;color:#1e293b;margin:0;font-size:14px;">${val||'—'}</p>
    </div>`;
}

function status(msg) {
    document.getElementById('ord-status').style.display = 'block';
    document.getElementById('ord-status').textContent = msg;
    document.getElementById('ord-table-wrap').style.display = 'none';
    document.getElementById('ord-pager').style.display = 'none';
}

// ─── Load ─────────────────────────────────────────────
async function loadOrders() {
    status('Loading orders...');
    try {
        const [orders, custs, tailors, meas] = await Promise.all([
            apiFetch('/api/orders'),
            apiFetch('/api/customers'),
            apiFetch('/api/tailors'),
            apiFetch('/api/measurements')
        ]);

        ALL = orders || [];

        // Dropdowns
        document.getElementById('o-customer').innerHTML =
            '<option value="">Select Customer</option>' +
            (custs||[]).map(c => `<option value="${c._id||c.id}">${c.customerName||c.name}</option>`).join('');
        document.getElementById('o-tailor').innerHTML =
            '<option value="">— None —</option>' +
            (tailors||[]).map(t => `<option value="${t._id||t.id}">${t.name}</option>`).join('');
        document.getElementById('o-measurement').innerHTML =
            '<option value="">— None —</option>' +
            (meas||[]).map(m => `<option value="${m._id||m.id}">${m.title||('Measurement #'+(m._id||m.id))}</option>`).join('');

        render();
    } catch(e) {
        status('Failed to load orders: ' + e.message);
        console.error('[Orders] loadOrders error:', e);
    }
}

// ─── Filter ───────────────────────────────────────────
function filter() {
    let list = [...ALL];

    // Tab filter
    if (TAB !== 'all') {
        list = list.filter(o => {
            const t = tok(o.status);
            if (TAB === 'pending')    return t === 'pending';
            if (TAB === 'inprogress') return t === 'inprogress';
            if (TAB === 'completed')  return t === 'completed';
            return true;
        });
    }

    // Search filter
    if (SEARCH) {
        list = list.filter(o => {
            const name = (o.customerId?.customerName || '').toLowerCase();
            const svcs = parseServices(o.services).join(' ').toLowerCase();
            return name.includes(SEARCH) || svcs.includes(SEARCH);
        });
    }

    return list;
}

// ─── Render ───────────────────────────────────────────
function render() {
    VIEW = filter();

    const total = VIEW.length;
    const pages = Math.ceil(total / PER) || 1;
    if (PAGE > pages) PAGE = pages;

    const start = (PAGE - 1) * PER;
    const slice = VIEW.slice(start, start + PER);

    document.getElementById('ord-status').style.display = 'none';

    if (total === 0) {
        status(TAB === 'all' ? 'No orders yet. Click "+ Add Order" to create one.' :
               `No "${document.querySelector('.tab-btn.active').textContent}" orders found.`);
        return;
    }

    document.getElementById('ord-table-wrap').style.display = 'block';

    document.getElementById('ord-tbody').innerHTML = slice.map((o, i) => {
        const svcs = parseServices(o.services).join(', ') || '—';
        const custName = o.customerId?.customerName || '—';
        const total = o.userDefinedTotal || o.calculatedTotal || o.totalAmount || 0;
        const idx = start + i;
        return `<tr>
            <td style="font-weight:700;color:#1e293b;">${custName}</td>
            <td style="font-size:13px;color:#475569;">${svcs}</td>
            <td style="text-align:center;">${badge(o.status)}</td>
            <td style="font-size:13px;">${formatDate(o.targetDeliveryDate)}</td>
            <td style="font-size:13px;color:#64748b;">${o.paymentMethod||'—'}</td>
            <td style="font-weight:800;color:var(--primary);">₹ ${total}</td>
            <td style="text-align:center;"><button class="btn-view" onclick="viewOrd(${idx})"><i data-lucide="eye" style="width:15px;height:15px;"></i></button></td>
            <td style="text-align:center;"><button class="btn-edit-icon" onclick="editOrd(${idx})"><i data-lucide="edit" style="width:15px;height:15px;"></i></button></td>
            <td style="text-align:center;"><button class="btn-delete" onclick="delOrd(${o._id||o.id})"><i data-lucide="trash-2" style="width:15px;height:15px;"></i></button></td>
        </tr>`;
    }).join('');

    // Pagination
    if (total <= PER) {
        document.getElementById('ord-pager').style.display = 'none';
    } else {
        document.getElementById('ord-pager').style.display = 'flex';
        document.getElementById('ord-pager-info').textContent = `Showing ${start+1}–${Math.min(start+PER, total)} of ${total}`;
        document.getElementById('ord-pager-pages').textContent = `${PAGE} / ${pages}`;
    }

    lucide.createIcons();
}

// ─── Tab Switch ───────────────────────────────────────
function setTab(tab, btn) {
    TAB = tab; PAGE = 1;
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    render();
}

// ─── Pagination ───────────────────────────────────────
function prevPage() { if (PAGE > 1) { PAGE--; render(); } }
function nextPage() { if (PAGE < Math.ceil(VIEW.length/PER)) { PAGE++; render(); } }

// ─── View Modal ───────────────────────────────────────
function viewOrd(idx) {
    const o = VIEW[idx]; if (!o) return;
    const custName = o.customerId?.customerName || '—';
    const svcs = parseServices(o.services).join(', ') || '—';
    const total = o.userDefinedTotal || o.calculatedTotal || o.totalAmount || 0;
    document.getElementById('view-ord-sub').textContent = custName;
    document.getElementById('view-order-content').innerHTML =
        field('Status', badge(o.status)) +
        field('Services', svcs) +
        field('Delivery Date', formatDate(o.targetDeliveryDate)) +
        field('Assigned Tailor', o.assignedTailor?.name || '—') +
        field('Payment Method', o.paymentMethod || '—') +
        `<div style="background:linear-gradient(135deg,#EEF2FF,#E0E7FF);border-radius:10px;padding:12px 14px;border:1px solid #c7d2fe;">
            <p style="font-size:11px;font-weight:700;color:#4F46E5;text-transform:uppercase;margin:0 0 4px;">Total Amount</p>
            <p style="font-weight:900;color:#4F46E5;margin:0;font-size:26px;">₹ ${total}</p>
        </div>`;
    openModal('view-order-modal');
    lucide.createIcons();
}

// ─── Edit Modal ───────────────────────────────────────
function editOrd(idx) {
    const o = VIEW[idx]; if (!o) return;
    document.getElementById('order-modal-title').textContent = 'Edit Order';
    document.getElementById('order-modal-sub').textContent = 'Update the order details below';
    document.getElementById('order-edit-id').value = o._id || o.id;
    document.getElementById('o-customer').value = o.customerId?._id || o.customerId?.id || o.customerId || '';
    document.getElementById('o-tailor').value = o.assignedTailor?._id || o.assignedTailor?.id || o.assignedTailorId || '';
    document.getElementById('o-measurement').value = o.measurementId?._id || o.measurementId?.id || o.measurementId || '';
    document.getElementById('o-services').value = parseServices(o.services).join(', ');
    document.getElementById('o-date').value = o.targetDeliveryDate ? o.targetDeliveryDate.slice(0,10) : '';
    document.getElementById('o-status').value = o.status || 'Pending';
    document.getElementById('o-payment').value = o.paymentMethod || 'Pending';
    document.getElementById('o-total').value = o.userDefinedTotal || o.calculatedTotal || o.totalAmount || 0;
    openModal('order-modal');
}

// ─── Add ──────────────────────────────────────────────
function openAdd() {
    document.getElementById('order-modal-title').textContent = 'Add Order';
    document.getElementById('order-modal-sub').textContent = 'Fill in the details to create a new order';
    document.getElementById('order-edit-id').value = '';
    ['o-services'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('o-total').value = '0';
    document.getElementById('o-date').value = '';
    ['o-status', 'o-payment', 'o-customer', 'o-tailor', 'o-measurement'].forEach(id => {
        document.getElementById(id).selectedIndex = 0;
    });
    openModal('order-modal');
}

// ─── Save ─────────────────────────────────────────────
async function saveOrder() {
    const id = document.getElementById('order-edit-id').value;
    const body = {
        customerId:       document.getElementById('o-customer').value,
        assignedTailorId: document.getElementById('o-tailor').value || null,
        measurementId:    document.getElementById('o-measurement').value || null,
        services:         document.getElementById('o-services').value.split(',').map(s=>s.trim()).filter(Boolean),
        targetDeliveryDate: document.getElementById('o-date').value || null,
        status:           document.getElementById('o-status').value,
        paymentMethod:    document.getElementById('o-payment').value,
        userDefinedTotal: parseFloat(document.getElementById('o-total').value) || 0
    };
    if (!body.customerId) return showToast('Please select a customer', 'error');
    try {
        if (id) await apiFetch(`/api/orders/${id}`, 'PUT', body);
        else    await apiFetch('/api/orders', 'POST', body);
        closeModal('order-modal');
        showToast(id ? 'Order updated!' : 'Order created!');
        loadOrders();
    } catch(e) { showToast('Error: ' + e.message, 'error'); }
}

// ─── Delete ───────────────────────────────────────────
async function delOrd(id) {
    if (!confirm('Delete this order permanently?')) return;
    try { await apiFetch(`/api/orders/${id}`, 'DELETE'); showToast('Order deleted'); loadOrders(); }
    catch(e) { showToast('Delete failed: ' + e.message, 'error'); }
}

function openModal(id)  { document.getElementById(id).classList.add('show'); }
function closeModal(id) { document.getElementById(id).classList.remove('show'); }

// ─── Init ─────────────────────────────────────────────
loadOrders();
</script>
}
