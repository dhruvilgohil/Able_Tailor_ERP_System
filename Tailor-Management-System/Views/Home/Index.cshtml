@{
    ViewData["Title"] = "Dashboard";
}

<div style="display:flex;flex-direction:column;gap:var(--spacing-2xl);">

    <!-- STAT CARDS (React: grid 4 cols, 24px gap) -->
    <div class="stats-grid">
        <div class="stat-card">
            <div>
                <p class="stat-label">Total Customer</p>
                <h3 class="stat-value" id="stat-customers">—</h3>
            </div>
            <div style="color:var(--primary);opacity:0.8;">
                <i data-lucide="users" style="width:28px;height:28px;"></i>
            </div>
        </div>
        <div class="stat-card">
            <div>
                <p class="stat-label">Total Orders</p>
                <h3 class="stat-value" id="stat-orders">—</h3>
            </div>
            <div style="color:var(--primary);opacity:0.8;">
                <i data-lucide="receipt" style="width:28px;height:28px;"></i>
            </div>
        </div>
        <div class="stat-card">
            <div>
                <p class="stat-label">Pending Orders</p>
                <h3 class="stat-value" id="stat-pending">—</h3>
            </div>
            <div style="color:var(--primary);">
                <i data-lucide="clock" style="width:28px;height:28px;"></i>
            </div>
        </div>
        <div class="stat-card">
            <div>
                <p class="stat-label">Total Income</p>
                <h3 class="stat-value" id="stat-income">—</h3>
            </div>
            <div style="color:var(--primary);opacity:0.8;">
                <i data-lucide="wallet" style="width:28px;height:28px;"></i>
            </div>
        </div>
    </div>

    <!-- RECENT ORDERS TABLE (React: white card, border-collapse separate, borderSpacing 0 8px) -->
    <div style="background-color:var(--surface);border-radius:12px;box-shadow:var(--shadow-sm);overflow:hidden;padding:8px;">
        <div id="dash-loading" style="padding:32px;text-align:center;color:#9CA3AF;">Loading orders...</div>
        <table class="dashboard-table" id="dash-table" style="display:none;">
            <thead>
                <tr>
                    <th>Customer Name</th>
                    <th class="center">Services</th>
                    <th class="center">Status</th>
                    <th class="center">Assigned Tailor</th>
                    <th class="center">Date</th>
                    <th class="center"></th>
                </tr>
            </thead>
            <tbody id="dash-tbody"></tbody>
        </table>
    </div>
</div>

<!-- View Order Modal -->
<div class="modal-overlay" id="view-order-modal">
    <div class="modal-box">
        <div class="modal-header-title">
            <h2>Order Details</h2>
        </div>
        <div class="modal-divider"></div>
        <div id="view-order-content"></div>
        <button class="btn-primary-full" onclick="closeModal('view-order-modal')">Close</button>
    </div>
</div>

@section Scripts {
<script>
async function loadDashboard() {
    try {
        const [customers, orders, income] = await Promise.all([
            apiFetch('/api/customers'),
            apiFetch('/api/orders'),
            apiFetch('/api/income')
        ]);

        document.getElementById('stat-customers').textContent = customers.length;
        document.getElementById('stat-orders').textContent = orders.length;
        document.getElementById('stat-pending').textContent = orders.filter(o => o.status === 'Pending').length;
        const totalIncome = income.reduce((s, i) => s + Number(i.amount || 0), 0);
        document.getElementById('stat-income').textContent = '₹ ' + totalIncome.toLocaleString();

        const recent = (orders || []).slice(0, 5);
        const tbody = document.getElementById('dash-tbody');
        tbody.innerHTML = recent.map(o => {
            const dateStr = new Date(o.createdAt).toLocaleDateString('en-GB').replace(/\//g, '-');
            return `<tr style="background-color:var(--surface);">
                <td>${o.customerId?.customerName || o.customerId?.name || 'Unknown'}</td>
                <td class="center">${Array.isArray(o.services) ? o.services.join(', ') : (o.services || '')}</td>
                <td class="center">${renderReactStatusBadge(o.status)}</td>
                <td class="center">${o.assignedTailor?.name || 'Unassigned'}</td>
                <td class="center">${dateStr}</td>
                <td class="center">
                    <button class="btn-view" onclick='viewOrder(${JSON.stringify(o)})'>View</button>
                </td>
            </tr>`;
        }).join('');

        document.getElementById('dash-loading').style.display = 'none';
        document.getElementById('dash-table').style.display = 'table';
        lucide.createIcons();
    } catch(e) {
        document.getElementById('dash-loading').textContent = 'Error loading. Is backend running on port 5000?';
    }
}

// Exact React status badge colors
function renderReactStatusBadge(status) {
    const styles = {
        'Completed':   'background:#A7F3D0;color:#047857;',
        'In Progress': 'background:#FDE68A;color:#B45309;',
        'Pending':     'background:#E5E7EB;color:#374151;',
    };
    const s = styles[status] || 'background:#FF8A8A;color:#FFFFFF;';
    return `<span style="padding:6px 24px;border-radius:20px;font-size:14px;font-weight:500;${s}">${status}</span>`;
}

function viewOrder(o) {
    document.getElementById('view-order-content').innerHTML = `
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;">Customer</p><p style="font-weight:700;">${o.customerId?.customerName||'—'}</p></div>
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;">Status</p>${renderReactStatusBadge(o.status)}</div>
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;">Services</p><p>${(o.services||[]).join(', ')||'—'}</p></div>
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;">Delivery</p><p>${formatDate(o.targetDeliveryDate)}</p></div>
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;">Tailor</p><p>${o.assignedTailor?.name||'—'}</p></div>
            <div><p style="font-size:12px;font-weight:600;color:#6B7280;">Payment</p><p>${o.paymentMethod||'—'}</p></div>
            <div style="grid-column:span 2;"><p style="font-size:12px;font-weight:600;color:#6B7280;">Total</p><p style="font-weight:800;font-size:24px;color:#4F46E5;">₹ ${o.userDefinedTotal||o.calculatedTotal||0}</p></div>
        </div>`;
    openModal('view-order-modal');
}

function openModal(id) { document.getElementById(id).classList.add('show'); }
function closeModal(id) { document.getElementById(id).classList.remove('show'); }

loadDashboard();
</script>
}
