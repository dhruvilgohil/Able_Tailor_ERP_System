@{
    ViewData["Title"] = "Inventory";
}

<div class="inventory-wrapper">

    <!-- ===== CARDS ===== -->
    <div class="inventory-cards">
        <div class="inv-card">
            <div class="inv-icon blue-bg">📦</div>
            <div>
                <div class="inv-title">Total Items</div>
                <div class="inv-value">200</div>
            </div>
        </div>

        <div class="inv-card">
            <div class="inv-icon green-bg">💰</div>
            <div>
                <div class="inv-title">Total Inventory Price</div>
                <div class="inv-value">₹ 4,50,000</div>
            </div>
        </div>

        <div class="inv-card">
            <div class="inv-icon red-bg">📉</div>
            <div>
                <div class="inv-title">Low Stock Items</div>
                <div class="inv-value">200</div>
            </div>
        </div>
    </div>


    <!-- ===== TABLE HEADER ===== -->
    <div class="table-header-box">
        <div class="header-row">
            <div class="col item">Item Name</div>
            <div class="col category">Category</div>
            <div class="col stock">Stock Details</div>
            <div class="col price">Unit Price</div>
            <div class="col Details">Stock</div>
            <div class="col action">Edit</div>
            <div class="col action">Delete</div>
        </div>
    </div>

    <!-- ===== TABLE BODY ===== -->
    <div class="table-body-box">

        @for (int i = 0; i < 5; i++)
        {
            <div class="body-row">
                <div class="col item">Raymond Black</div>
                <div class="col category">Fabric</div>
                <div class="col stock">12 Meter</div>
                <div class="col price">₹ 850</div>
                <div class="red">Low Stock</div>

                <div class="col action">
                    <button class="btn-edit">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 20h9" />
                            <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
                        </svg>
                    </button>
                </div>

                <div class="col action">
                    <button class="btn-delete">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="3 6 5 6 21 6" />
                            <path d="M19 6l-1 14H6L5 6" />
                            <path d="M10 11v6" />
                            <path d="M14 11v6" />
                        </svg>
                    </button>
                </div>
            </div>
        }

    </div>


    <!-- ===== FOOTER ===== -->
    <div class="inventory-footer">

        <div class="left-section">
            <button class="add-btn">Add Item</button>
        </div>

        <div class="right-section">
            <div class="pagination">
                <button class="page-arrow">&#10094;</button>
                <button class="page-number active">1</button>
                <button class="page-number">2</button>
                <button class="page-number">3</button>
                <span class="dots">....</span>
                <button class="page-number">5</button>
                <button class="page-arrow">&#10095;</button>
            </div>
        </div>

    </div>

</div>
